    <item>
      <title>ssl/tls证书自签</title>
      <link>http://localhost:1313/posts/other/%E8%AF%81%E4%B9%A6%E8%87%AA%E7%AD%BE/</link>
      <pubDate>Thu, 21 May 2020 09:18:25 +0800</pubDate>
      <guid>http://localhost:1313/posts/other/%E8%AF%81%E4%B9%A6%E8%87%AA%E7%AD%BE/</guid>
      <description>&lt;blockquote&gt;
&lt;p&gt;go1.15以后必须是SAN证书&lt;/p&gt;&lt;/blockquote&gt;
&lt;blockquote&gt;
&lt;p&gt;需要下载openssl&lt;/p&gt;
&lt;p&gt;mac下载方法：brew install openssl&lt;/p&gt;&lt;/blockquote&gt;
&lt;h3 id=&#34;生成-ca-根证书&#34;&gt;生成 CA 根证书&lt;/h3&gt;
&lt;blockquote&gt;
&lt;p&gt;genrsa -out ca.key 2048&lt;/p&gt;&lt;/blockquote&gt;
&lt;blockquote&gt;
&lt;p&gt;req -new -x509 -days 3650 -key ca.key -out ca.pem&lt;/p&gt;&lt;/blockquote&gt;
&lt;h3 id=&#34;生成服务端证书&#34;&gt;生成服务端证书&lt;/h3&gt;
&lt;blockquote&gt;
&lt;p&gt;genpkey -algorithm RSA -out server.key&lt;/p&gt;&lt;/blockquote&gt;
&lt;blockquote&gt;
&lt;p&gt;req -new -nodes -key server.key -out server.csr -days 3650 -subj &amp;ldquo;/C=cn/OU=custer/O=custer/CN=localhost&amp;rdquo; -config ./openssl.cnf -extensions v3_req&lt;/p&gt;&lt;/blockquote&gt;
&lt;blockquote&gt;
&lt;p&gt;x509 -req -days 3650 -in server.csr -out server.pem -CA ca.pem -CAkey ca.key -CAcreateserial -extfile ./openssl.cnf -extensions v3_req&lt;/p&gt;&lt;/blockquote&gt;
&lt;h3 id=&#34;生成客户端证书&#34;&gt;生成客户端证书&lt;/h3&gt;
&lt;blockquote&gt;
&lt;p&gt;genpkey -algorithm RSA -out client.key&lt;/p&gt;</description>
